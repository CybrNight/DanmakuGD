[sub_resource type="GDScript" id="GDScript_xfwul"]
script/source = "extends Sprite2D

@export var spawner: Node2D;

var timer = 0;
var base = 0;
var global = 0;

func _ready():
	_late_ready.call_deferred()

func _late_ready():
	if not Engine.is_editor_hint():
		spawner.Spawn(\"maybe\", 0, 0);
		pass

func _process(delta):
	if not Engine.is_editor_hint():
		timer += delta;
		global += delta;
		if  global < 5 and timer > 0.5:
			spawner.SpawnFunction(\"cos\", 0, 5);		
			spawner.Spawn(\"maybe\", 0, 0);
			timer = 0;
	
"


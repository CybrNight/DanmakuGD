<?xml version="1.0" ?>
<!DOCTYPE bulletml SYSTEM "bulletml.dtd">

<bulletml type="vertical"
		  xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
	
	 <!-- BulletML File is made of ACTIONS -->
	<!-- Bullets store their owns ACTIONS TOO! Action->FireBullet->Action->etc... -->
	<action label="top">
		
	   <!-- The main loop, until the boss is destroyed -->
		 <!-- REPEAT tag encase an action within it to repeat-->
		<repeat>
			<!-- The main loop, until the boss is destroyed -->
			<times>9999</times>
			 <!-- ACTIONS can have many different subactions -->
			<action>
				<actionRef label = "pentagram"/>
			</action>
		</repeat>
		<vanish/>

	</action>

	<action label = "pentagram">
		<action>
				<repeat>
					<times>40</times>
					 <!-- Main action here handles spawning the first part of the line at 72 degrees -->
					<fire>
						<direction type="absolute">72 + (10 *$rand)</direction>
						<speed type="relative">1.5</speed>
						<bulletRef label="starPath"/>
					</fire>
				</repeat>
				<wait>10</wait>
			</action>
	</action>
	
	 <!-- This is the bullet that actually starts the star path -->
	<bullet label="starPath">
		<speed>2.5 * $rand</speed>
		<repeat>
		<times>3 + 5*$rand</times>
		 <!-- Bullets can store their owns ACTIONS TOO! Action->FireBullet->Action->etc... -->
		<action>
			<changeDirection>
				<direction type="sequence">-72</direction>
			</changeDirection>
			<wait>100 + (5 * $rand)</wait>
			<changeDirection>
				<direction type="sequence">-72</direction>
			</changeDirection>
		</action>
		</repeat>
		<changeSpeed>
			<speed type = "absolute">0</speed>
		</changeSpeed>
		<wait>500 + (200 * $rand)</wait>
		<changeSpeed>
			<speed type = "absolute">3</speed>
		</changeSpeed>
		<changeDirection>
				<direction type="aim">cos($tick)</direction>
		</changeDirection>
	</bullet>
	
	<bullet label = "starBullet">
		<speed>0</speed>
		<action>
			<wait>10</wait>
			<fire>
				<direction type="aim">0</direction>
				<speed type="relative">5</speed>
				<bullet/>
			</fire>
		</action>
		
			
	</bullet>


</bulletml>
